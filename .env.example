SLACK_BOT_TOKEN=replace_with_xoxb_bot_token
SLACK_SIGNING_SECRET=replace_with_signing_secret
SLACK_APP_TOKEN=replace_with_xapp_app_level_token
OPENROUTER_API_KEY=replace_with_openrouter_api_key
OPENROUTER_MODEL=openrouter/free
GOOGLE_DRIVE_UPLOAD_FOLDER_ID=replace_with_google_drive_folder_id

# Recommended when Drive says service accounts do not have storage quota.
GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost
GOOGLE_OAUTH_REFRESH_TOKEN=replace_with_generated_refresh_token

# Alternative for service-account auth, usually only works cleanly with Shared Drives.
# GOOGLE_AUTH_MODE=service_account
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json
